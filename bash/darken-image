#! /bin/bash

# Script: darken-image
# Description: Darkens an image using ImageMagick's convert command.
# Usage: darken-image <image_file> [darkness_percentage]
# Example: darken-image image.png 50

if [[ $# -lt 1 ]]; then
    echo "Usage: darken-image <image> [percent]"
    echo
    echo "Darkens an image using ImageMagick."
    echo
    echo "Arguments:"
    echo "    image                 Path to image file."
    echo "    percentage            Darkness level (0-100). Default: 50"
    exit 1
fi

image="$1"
darkness="${2:-50}"

if [[ ! -f "$image" ]]; then
    echo "Error: '$image' not found."
    exit 1
fi

base="${image%.*}"
ext="${image##*.}"
out="${base}_dark${darkness}.${ext}"

magick "$image" -fill black -colorize "$darkness" "$out"
